# =====================================================================
# Plantilla de variables de entorno. Copia a .env y rellena valores.
# NUNCA commitear .env con secretos reales.
# =====================================================================

# Entorno: development | staging | production
ENV=development

# --- Base de datos -------------------------------------------------
# Formato: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# Variables que docker-compose.dev.yml inyecta a Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- Auth / JWT ----------------------------------------------------
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-please-generate-a-strong-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Frontend estáticos (solo prod) --------------------------------
# Path absoluto a frontend/dist dentro del contenedor.
FRONTEND_DIST_PATH=/app/frontend/dist

# --- CORS ----------------------------------------------------------
# Lista separada por comas. En prod, sirviendo todo desde el mismo origen,
# suele bastar con dejarla vacía.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Logging -------------------------------------------------------
LOG_LEVEL=INFO
